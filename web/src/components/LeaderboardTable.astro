---
import { Image } from "astro:assets";
import { buildShareButtonText, getSharePath } from "../lib/share";
import { getI18n, getNumberLocale, type Locale } from "../lib/i18n";
import type {
  LeaderboardEntry,
  LeaderboardSortDirection,
  LeaderboardSortKey,
} from "../lib/types";

type Props = {
  entries: LeaderboardEntry[];
  sortKey: LeaderboardSortKey;
  sortDirection: LeaderboardSortDirection;
  locale: Locale;
};

const { entries, sortKey, sortDirection, locale } = Astro.props;
const t = getI18n(locale);
const numberLocale = getNumberLocale(locale);

const sortLabels: Record<LeaderboardSortKey, string> = t.leaderboard.sortLabels;

const sortKeys: LeaderboardSortKey[] = ["profanityCount", "tokens", "sbai", "updatedAt"];
const directionItems: LeaderboardSortDirection[] = ["desc", "asc"];

function hrefFor(nextSortKey: LeaderboardSortKey, nextDirection: LeaderboardSortDirection) {
  const search = new URLSearchParams({
    sort: nextSortKey,
    dir: nextDirection,
  });
  return `/?${search.toString()}`;
}
---

<section class="surface leaderboard">
  <div class="leaderboard-header">
    <h2 class="section-title">{t.leaderboard.sectionTitle}</h2>
    <div class="leaderboard-tools">
      <div class="tool-group">
        {
          sortKeys.map((item) => (
            <a
              href={hrefFor(item, sortDirection)}
              class:list={["tool-chip", sortKey === item && "is-active"]}
            >
              {sortLabels[item]}
            </a>
          ))
        }
      </div>
      <div class="tool-group">
        {
          directionItems.map((item) => (
            <a
              href={hrefFor(sortKey, item)}
              class:list={["tool-chip", sortDirection === item && "is-active"]}
            >
              {t.leaderboard.directionLabels[item]}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="table-shell">
    <table>
      <thead>
        <tr>
          <th>{t.leaderboard.columns.rank}</th>
          <th>{t.leaderboard.columns.account}</th>
          <th>{t.leaderboard.columns.profanityCount}</th>
          <th>{t.leaderboard.columns.tokens}</th>
          <th>{t.leaderboard.columns.sbai}</th>
          <th>{t.leaderboard.columns.updatedAt}</th>
          <th>{t.leaderboard.columns.share}</th>
        </tr>
      </thead>
      <tbody>
        {
          entries.map((entry) => {
            const profileHref = `/u/${encodeURIComponent(entry.login)}`;
            const shareHref = getSharePath(entry.githubId);
            const shareText = buildShareButtonText(entry, locale);

            return (
              <tr>
                <td class="rank">#{entry.rank}</td>
                <td>
                  <a href={profileHref} class="term-cell">
                    <Image
                      src={entry.avatarUrl}
                      alt={entry.displayName}
                      class="term-image"
                      width={36}
                      height={36}
                    />
                    <span>
                      <span class="term-text">{entry.displayName}</span>
                      <span class="term-subtext">@{entry.login}</span>
                    </span>
                  </a>
                </td>
                <td>{entry.profanityCount.toLocaleString(numberLocale)}</td>
                <td>{entry.tokens.toLocaleString(numberLocale)}</td>
                <td class="change">{entry.sbai.toFixed(3)}</td>
                <td>{new Date(entry.updatedAt).toLocaleDateString(numberLocale)}</td>
                <td class="share-cell">
                  <button
                    type="button"
                    class="share-button"
                    data-share-url={shareHref}
                    data-share-text={shareText}
                    aria-label={`${entry.displayName}: ${t.leaderboard.shareAriaLabel}`}
                  >
                    <svg viewBox="0 0 24 24" aria-hidden="true" class="share-button-icon">
                      <path
                        fill="currentColor"
                        d="M18.244 2H21l-6.04 6.904L22 22h-5.52l-4.323-6.924L6.1 22H3.34l6.46-7.386L2 2h5.66l3.908 6.276zm-.968 18h1.527L6.83 3.894H5.192z"
                      />
                    </svg>
                    <span>{t.leaderboard.shareOnX}</span>
                  </button>
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</section>

<script>
  for (const button of document.querySelectorAll(".share-button")) {
    button.addEventListener("click", (event) => {
      event.preventDefault();

      const shareUrl = button.getAttribute("data-share-url");
      const shareText = button.getAttribute("data-share-text") || "absolute-right leaderboard";

      if (!shareUrl) {
        return;
      }

      const absoluteUrl = new URL(shareUrl, window.location.origin).toString();
      const twitterIntentUrl = new URL("https://twitter.com/intent/tweet");
      twitterIntentUrl.searchParams.set("text", shareText);
      twitterIntentUrl.searchParams.set("url", absoluteUrl);

      const popup = window.open(twitterIntentUrl.toString(), "_blank", "noopener,noreferrer");
      if (popup) {
        popup.opener = null;
      }
    });
  }
</script>

<style>
  .leaderboard {
    padding: 18px;
  }

  .leaderboard-header {
    margin-bottom: 14px;
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .leaderboard-tools {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .tool-group {
    display: inline-flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tool-chip {
    text-decoration: none;
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.02em;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.76);
    padding: 8px 10px;
    border-radius: 8px;
    transition: border-color 140ms ease, color 140ms ease, background 140ms ease;
  }

  .tool-chip.is-active {
    color: var(--accent);
    border-color: rgba(255, 91, 97, 0.34);
    background: rgba(255, 91, 97, 0.1);
  }

  .table-shell {
    overflow: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th,
  td {
    text-align: left;
    padding: 14px 12px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    vertical-align: middle;
  }

  th {
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(246, 248, 251, 0.92);
    position: sticky;
    top: 0;
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  .rank {
    font-weight: 900;
    color: var(--accent);
  }

  .term-cell {
    display: flex;
    align-items: center;
    gap: 10px;
    color: inherit;
    text-decoration: none;
  }

  .term-image {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    object-fit: cover;
    flex: 0 0 auto;
  }

  .term-text {
    display: block;
    font-weight: 800;
  }

  .term-subtext {
    display: block;
    color: var(--muted);
    font-size: 12px;
    margin-top: 3px;
  }

  .change {
    color: #0d7a84;
    font-weight: 800;
  }

  .share-cell {
    width: 132px;
  }

  .share-button {
    min-height: 34px;
    min-width: 112px;
    padding: 0 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--text);
    font: inherit;
    font-weight: 700;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    cursor: pointer;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }

  .share-button-icon {
    width: 14px;
    height: 14px;
    flex: 0 0 auto;
  }

  .share-button:hover,
  .share-button:focus-visible {
    border-color: rgba(15, 163, 177, 0.45);
    background: rgba(15, 163, 177, 0.12);
    color: #0d7a84;
  }

  @media (max-width: 980px) {
    .leaderboard-header {
      flex-direction: column;
    }

    .leaderboard-tools {
      justify-content: flex-start;
    }
  }
</style>
